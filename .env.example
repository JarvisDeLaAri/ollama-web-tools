# OllamaWebTools Configuration
# Copy to .env and set values

# API bind
PORT=10021
HOST=127.0.0.1

# Optional local Ollama health target
OLLAMA_URL=http://127.0.0.1:11434

# Label only (returned in API responses)
OLLAMA_MODEL=kimi-k2.5:cloud

# Logging level: debug|info|warning|error
LOG_LEVEL=info

# REQUIRED: Ollama Web API key from https://ollama.com/settings/keys
OLLAMA_API_KEY=
